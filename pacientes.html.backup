<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Pharma Guard - Pacientes</title>
    <link rel="stylesheet" href="style_profissional.css">
</head>
<body>
    <header id="barra-superior">
        <h1>AI Pharma Guard</h1>
    </header>
    <div id="container">
        <nav id="menu-lateral">
            <h2>Menu</h2>
            <ul>
                <li><a href="dashboard.html">Dashboard</a></li>
                <li><a href="pacientes.html">Pacientes</a></li>
                <li><a href="medicamentos.html">Medicamentos</a></li>
                <li><a href="interacoes.html">Interações</a></li>
            </ul>
        </nav>
        <main>
            <h2>Cadastro de Paciente</h2>
            <form>
                <label for="nome">Nome:</label>
                <input type="text" id="nome" name="nome" required>
                <label for="idade">Idade:</label>
                <input type="number" id="idade" name="idade" required>
                <label for="sexo">Sexo:</label>
                <select id="sexo" name="sexo">
                    <option value="masculino">Masculino</option>
                    <option value="feminino">Feminino</option>
                </select>
                <label for="doencas">Doenças:</label>
                <input type="text" id="doencas" name="doencas">
                <label for="medicamentos">Medicamentos em uso:</label>
                <input type="text" id="medicamentos" name="medicamentos">
                <button type="submit">Cadastrar Paciente</button>
            </form>
            <h3>Lista de Pacientes</h3>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Idade</th>
                        <th>Sexo</th>
                        <th>Doenças</th>
                        <th>Medicamentos</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Os dados dos pacientes serão inseridos aqui -->
                </tbody>
            </table>
        </main>
    </div>
    <script src="app.js"></script>
</body>
</html>