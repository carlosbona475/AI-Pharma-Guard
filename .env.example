# Supabase (PostgreSQL) - AI Pharma Guard
# Copie para .env e preencha os valores. No Render, use variáveis de ambiente.

SUPABASE_HOST=
SUPABASE_DB=postgres
SUPABASE_USER=
SUPABASE_PASS=
SUPABASE_PORT=5432
SUPABASE_SSLMODE=require

# Opcional: fallback com nomes antigos (DB_*)
# DB_HOST=
# DB_NAME=postgres
# DB_USER=
# DB_PASS=
# DB_PORT=6543
# DB_SSLMODE=require
