# AI Pharma Guard — MySQL (Hostinger / local)
#
# 1) Copie este arquivo para a raiz do projeto com o nome:  .env
#    (PowerShell:  Copy-Item .env.example .env )
# 2) Preencha DB_NAME, DB_USER e DB_PASSWORD com os dados do painel (ex.: Hostinger → Bancos MySQL).
# 3) Nunca faça commit do arquivo .env (já está listado no .gitignore).
#
# Se a senha tiver caracteres especiais, use aspas: DB_PASSWORD="sua@senha"

DB_HOST=localhost
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_PORT=3306
BASE_URL=https://seu-dominio.com
