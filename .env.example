# Supabase (PostgreSQL) - AI Pharma Guard
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório (ele está no .gitignore).
# Em produção (ex: Render), use variáveis de ambiente do painel.

SUPABASE_HOST=
SUPABASE_DB=postgres
SUPABASE_USER=
SUPABASE_PASS=
SUPABASE_PORT=5432
SUPABASE_SSLMODE=require

# Opcional: fallback com nomes antigos (DB_*)
# DB_HOST=
# DB_NAME=postgres
# DB_USER=
# DB_PASS=
# DB_PORT=6543
# DB_SSLMODE=require
